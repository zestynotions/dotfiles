#!/bin/sh
# grep -E 'alias|# -' $HOME/.zshrc |sort > $HOME/.config/bin/shortcuts.sh
rg 'alias|# -' $HOME/.zshrc |cat > $HOME/.config/bin/shortcuts.sh

if [ -f "$HOME/Library/Mobile Documents/com~apple~CloudDocs/app_data_sync/private.sh" ]; then
rg 'alias' "$HOME/Library/Mobile Documents/com~apple~CloudDocs/app_data_sync/private.sh"|sort >> $HOME/.config/bin/shortcuts.sh
fi

bat -p $HOME/.config/bin/shortcuts.sh

exit 1
